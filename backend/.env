# backend/.env.example — Copy to .env and fill in values

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sfhub:sfhub_secret@localhost:5432/sflearnershub

# ─── Security ────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-256-bit-random-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000","https://sflearnershub.com"]

# ─── App ─────────────────────────────────────────────────────
DEBUG=false
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
