# Backend Environment Variables
# Copy this file to .env and fill in your values

# App Configuration
SECRET_KEY=your-256-bit-secret-key-here

# Database Configuration
# PostgreSQL connection string for asyncpg
# Format: postgresql+asyncpg://user:password@host:port/dbname
# For Supabase: postgresql+asyncpg://postgres:password@region.supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sflearnershub

# CORS Configuration
# For development: use "*" or ["http://localhost:3000"]
# For production: list specific origins as JSON array
CORS_ORIGINS=["https://yourdomain.vercel.app"]

# Optional: Media upload settings (defaults shown)
# UPLOAD_DIR=uploads
# MAX_UPLOAD_SIZE_MB=10
